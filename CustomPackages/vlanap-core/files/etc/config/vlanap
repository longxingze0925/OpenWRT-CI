config global 'main'
	option enabled '1'
	option bridge 'br-vlanap'
	option uplink 'lan1'
	option manage_network 'vlan254'
	option manage_vlan '254'
	option manage_ip '172.16.254.254'
	option manage_netmask '255.255.255.0'
	option gateway '172.16.254.1'
	option dns '172.16.254.1'
	option safe_timeout '180'
	option disable_existing_wifi '1'
	option disable_all_dhcp '1'
	option manage_firewall_zone 'vlanap_mgmt'
	option mac_mode 'auto'

config vlan 'vlan1'
	option id '1'
	option network 'vlan1'
	list tagged_port 'lan1'

config vlan 'vlan2'
	option id '2'
	option network 'vlan2'
	list tagged_port 'lan1'

config vlan 'vlan3'
	option id '3'
	option network 'vlan3'
	list tagged_port 'lan1'

config vlan 'vlan4'
	option id '4'
	option network 'vlan4'
	list tagged_port 'lan1'

config vlan 'vlan254'
	option id '254'
	option network 'vlan254'
	list tagged_port 'lan1'
	list untagged_port 'lan2'

config wifi 'vlan1_wifi'
	option network 'vlan1'
	option ssid 'WiFi-1'
	option encryption 'psk2+ccmp'
	option key 'change-this-password'

config wifi 'vlan2_wifi'
	option network 'vlan2'
	option ssid 'WiFi-2'
	option encryption 'psk2+ccmp'
	option key 'change-this-password'

config wifi 'vlan3_wifi'
	option network 'vlan3'
	option ssid 'WiFi-3'
	option encryption 'psk2+ccmp'
	option key 'change-this-password'

config wifi 'vlan4_wifi'
	option network 'vlan4'
	option ssid 'WiFi-4'
	option encryption 'psk2+ccmp'
	option key 'change-this-password'

config wifi 'vlan254_wifi'
	option network 'vlan254'
	option ssid 'WiFi-254'
	option encryption 'psk2+ccmp'
	option key 'change-this-password'
