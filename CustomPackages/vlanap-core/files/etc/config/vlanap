config global 'main'
	option enabled '1'
	option bridge 'br-vlanap'
	option uplink 'lan1'
	option manage_network 'home'
	option manage_vlan '10'
	option manage_ip '172.16.10.2'
	option manage_netmask '255.255.255.0'
	option gateway '172.16.10.1'
	option dns '172.16.10.1'
	option safe_timeout '180'
	option disable_existing_wifi '1'
	option disable_all_dhcp '1'

config vlan 'home'
	option id '10'
	option network 'home'
	list tagged_port 'lan1'
	list untagged_port 'lan2'

config vlan 'iot'
	option id '30'
	option network 'iot'
	list tagged_port 'lan1'
	list untagged_port 'lan3'

config wifi 'home_wifi'
	option network 'home'
	option ssid 'Home'
	option encryption 'psk2+ccmp'
	option key 'change-this-password'

config wifi 'iot_wifi'
	option network 'iot'
	option ssid 'IoT'
	option encryption 'psk2+ccmp'
	option key 'change-this-password'
