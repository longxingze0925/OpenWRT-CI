#!/bin/sh

CONFIG="vlanap"
BACKUP_ROOT="/etc/vlanap/backup"
SAFE_STATE="/tmp/vlanap-safe-rollback"
MANAGED_FLAG="vlanap_managed"
OUI_FILE="/usr/share/vlanap/oui-router-ap.txt"

. /lib/functions.sh

log() {
	echo "vlanap: $*"
}

die() {
	echo "vlanap: error: $*" >&2
	exit 1
}

usage() {
	cat <<'EOF'
Usage: vlanap <command>

Commands:
  apply       Apply /etc/config/vlanap immediately.
  apply-safe  Apply config and auto-rollback unless confirmed.
  confirm     Confirm a safe apply and cancel rollback.
  preset      Create a RouterOS trunk preset in /etc/config/vlanap.
  quick-apply Create the preset and apply it with safe rollback.
  batch-generate Create business Wi-Fi sections and their VLAN/network records.
  mac-generate Generate persistent Wi-Fi MACs.
  mac-clear   Clear configured Wi-Fi MAC.
  wifi-status Show configured and running Wi-Fi MAC addresses.
  backup      Back up network, wireless, dhcp, firewall, and dropbear configs.
  restore     Restore the latest backup, or pass a backup directory.
  status      Show vlanap config and generated state.
EOF
}

valid_name() {
	case "$1" in
		""|*[!A-Za-z0-9_]*)
			return 1
			;;
	esac
	return 0
}

valid_device_name() {
	case "$1" in
		""|*[!A-Za-z0-9_.-]*)
			return 1
			;;
	esac
	return 0
}

valid_vlan_id() {
	case "$1" in
		""|*[!0-9]*)
			return 1
			;;
	esac
	[ "$1" -ge 1 ] 2>/dev/null && [ "$1" -le 4094 ] 2>/dev/null
}

valid_ipv4_or_empty() {
	[ -z "$1" ] && return 0
	case "$1" in
		*.*.*.*)
			return 0
			;;
	esac
	return 1
}

valid_mac_or_empty() {
	[ -z "$1" ] && return 0

	case "$1" in
		[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f])
			return 0
			;;
	esac

	return 1
}

normalize_mac() {
	echo "$1" | tr 'A-F' 'a-f'
}

is_unicast_mac() {
	local first

	valid_mac_or_empty "$1" || return 1
	[ -n "$1" ] || return 1

	first=$((0x$(echo "$1" | cut -d: -f1)))
	[ $((first & 1)) -eq 0 ]
}

append_unique() {
	local var_name="$1"
	local item="$2"
	local current value

	[ -n "$item" ] || return 0
	eval "current=\"\${$var_name}\""

	for value in $current; do
		[ "$value" = "$item" ] && return 0
	done

	eval "$var_name=\"\$current \$item\""
}
contains_word() {
	local needle="$1"
	local value
	shift

	for value in "$@"; do
		[ "$value" = "$needle" ] && return 0
	done

	return 1
}

assert_unique_word() {
	local var_name="$1"
	local item="$2"
	local label="$3"
	local current value

	eval "current=\"\${$var_name}\""
	for value in $current; do
		[ "$value" = "$item" ] && die "duplicate $label: $item"
	done

	eval "$var_name=\"\$current \$item\""
}

collect_port() {
	local port="$1"

	valid_device_name "$port" || die "invalid port name: $port"
	append_unique PORTS "$port"
}

validate_tagged_port() {
	local port="$1"

	valid_device_name "$port" || die "invalid tagged port in VLAN $CURRENT_VLAN_ID: $port"
	assert_unique_word SECTION_PORTS "$port" "port in VLAN $CURRENT_VLAN_ID"
	append_unique PORTS "$port"
}

validate_untagged_port() {
	local port="$1"

	valid_device_name "$port" || die "invalid untagged port in VLAN $CURRENT_VLAN_ID: $port"
	[ "$port" != "$UPLINK" ] || die "uplink port $UPLINK must stay tagged, not untagged in VLAN $CURRENT_VLAN_ID"
	assert_unique_word SECTION_PORTS "$port" "port in VLAN $CURRENT_VLAN_ID"
	assert_unique_word ACCESS_PORTS "$port" "untagged access port"
	append_unique PORTS "$port"
}

collect_vlan_section() {
	VLAN_SECTIONS="$VLAN_SECTIONS $1"
}

collect_wifi_section() {
	WIFI_SECTIONS="$WIFI_SECTIONS $1"
}

collect_radio_section() {
	ALL_RADIOS="$ALL_RADIOS $1"
}

collect_wifi_radio() {
	append_unique WIFI_RADIOS "$1"
}

load_vlanap_config() {
	config_load "$CONFIG"

	config_get ENABLED main enabled "0"
	config_get BRIDGE main bridge "br-vlanap"
	config_get UPLINK main uplink "lan1"
	config_get MANAGE_NETWORK main manage_network ""
	config_get MANAGE_VLAN main manage_vlan ""
	config_get MANAGE_IP main manage_ip ""
	config_get MANAGE_NETMASK main manage_netmask "255.255.255.0"
	config_get GATEWAY main gateway ""
	config_get DNS main dns ""
	config_get SAFE_TIMEOUT main safe_timeout "180"
	config_get DISABLE_EXISTING_WIFI main disable_existing_wifi "1"
	config_get DISABLE_ALL_DHCP main disable_all_dhcp "1"
	config_get MANAGE_FIREWALL_ZONE main manage_firewall_zone "vlanap_mgmt"

	valid_device_name "$BRIDGE" || die "invalid bridge name: $BRIDGE"
	valid_device_name "$UPLINK" || die "invalid uplink port: $UPLINK"
	valid_name "$MANAGE_NETWORK" || die "invalid manage_network: $MANAGE_NETWORK"
	valid_vlan_id "$MANAGE_VLAN" || die "invalid manage_vlan: $MANAGE_VLAN"
	[ -n "$MANAGE_IP" ] || die "manage_ip is required"
	valid_ipv4_or_empty "$MANAGE_IP" || die "invalid manage_ip: $MANAGE_IP"
	valid_ipv4_or_empty "$GATEWAY" || die "invalid gateway: $GATEWAY"
	valid_ipv4_or_empty "$DNS" || die "invalid dns: $DNS"
	[ -z "$MANAGE_FIREWALL_ZONE" ] || valid_name "$MANAGE_FIREWALL_ZONE" || die "invalid manage_firewall_zone: $MANAGE_FIREWALL_ZONE"

	case "$SAFE_TIMEOUT" in
		""|*[!0-9]*)
			die "invalid safe_timeout: $SAFE_TIMEOUT"
			;;
	esac

	VLAN_SECTIONS=""
	WIFI_SECTIONS=""
	PORTS=""
	NETWORKS=""
	VLAN_IDS=""
	ACCESS_PORTS=""

	append_unique PORTS "$UPLINK"
	config_foreach collect_vlan_section vlan
	config_foreach collect_wifi_section wifi

	[ -n "$VLAN_SECTIONS" ] || die "no vlan section found in /etc/config/vlanap"
}

validate_vlan_sections() {
	local section id network manage_network_seen

	manage_network_seen=0

	for section in $VLAN_SECTIONS; do
		config_get id "$section" id
		config_get network "$section" network "$section"

		valid_vlan_id "$id" || die "invalid VLAN id in section $section: $id"
		valid_name "$network" || die "invalid network name in section $section: $network"
		assert_unique_word VLAN_IDS "$id" "VLAN id"
		assert_unique_word NETWORKS "$network" "network name"

		if [ "$network" = "$MANAGE_NETWORK" ]; then
			[ "$id" = "$MANAGE_VLAN" ] || die "manage_network $MANAGE_NETWORK uses VLAN $id, expected $MANAGE_VLAN"
			manage_network_seen=1
		fi

		CURRENT_VLAN_ID="$id"
		SECTION_PORTS=""
		config_list_foreach "$section" tagged_port validate_tagged_port
		config_list_foreach "$section" untagged_port validate_untagged_port
	done

	[ "$manage_network_seen" = "1" ] || die "manage_network $MANAGE_NETWORK not found in vlan sections"
}

validate_runtime_ports() {
	local port

	for port in $PORTS; do
		[ -e "/sys/class/net/$port" ] || die "port not found on this device: $port"
	done
}

validate_plain_wifi_key() {
	local key="$1"

	[ ${#key} -ge 8 ] || die "wifi key requires at least 8 characters"
	[ "$key" != "change-this-password" ] || die "wifi key still uses the default value"
}

validate_wifi_key() {
	local section="$1"
	local encryption="$2"
	local key="$3"

	case "$encryption" in
		none|"")
			return 0
			;;
	esac

	[ ${#key} -ge 8 ] || die "wifi section $section requires a key with at least 8 characters"
	[ "$key" != "change-this-password" ] || die "wifi section $section still uses the default key"
}

validate_wifi_sections() {
	local section network ssid encryption key macaddr

	for section in $WIFI_SECTIONS; do
		config_get network "$section" network
		config_get ssid "$section" ssid
		config_get encryption "$section" encryption "psk2+ccmp"
		config_get key "$section" key ""
		config_get macaddr "$section" macaddr ""

		valid_name "$network" || die "invalid wifi network in section $section: $network"
		contains_word "$network" $NETWORKS || die "wifi section $section references unknown network: $network"
		[ -n "$ssid" ] || die "missing ssid in wifi section $section"
		validate_wifi_key "$section" "$encryption" "$key"
		valid_mac_or_empty "$macaddr" || die "invalid macaddr in wifi section $section: $macaddr"
		[ -z "$macaddr" ] || is_unicast_mac "$macaddr" || die "wifi section $section macaddr must be a unicast MAC: $macaddr"
	done
}

prepare_config() {
	load_vlanap_config

	[ "$ENABLED" = "1" ] || die "/etc/config/vlanap is disabled"

	validate_vlan_sections
	validate_runtime_ports
	validate_wifi_sections
}

make_backup() {
	local ts backup file

	mkdir -p "$BACKUP_ROOT" || die "failed to create backup directory: $BACKUP_ROOT"
	ts="$(date +%Y%m%d-%H%M%S)-$$"
	backup="$BACKUP_ROOT/$ts"
	mkdir -p "$backup" || die "failed to create backup directory: $backup"

	for file in network wireless dhcp firewall dropbear; do
		[ -f "/etc/config/$file" ] && cp -p "/etc/config/$file" "$backup/$file"
	done

	rm -f "$BACKUP_ROOT/latest"
	ln -s "$backup" "$BACKUP_ROOT/latest" 2>/dev/null || true
	echo "$backup"
}

reload_services() {
	/etc/init.d/network reload >/dev/null 2>&1 || /etc/init.d/network restart >/dev/null 2>&1 || true
	command -v wifi >/dev/null 2>&1 && wifi reload >/dev/null 2>&1 || true
	/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
	/etc/init.d/firewall reload >/dev/null 2>&1 || true
	/etc/init.d/dropbear restart >/dev/null 2>&1 || true
}

restore_from() {
	local backup="$1"
	local file

	[ -d "$backup" ] || die "backup directory not found: $backup"

	for file in network wireless dhcp firewall dropbear; do
		[ -f "$backup/$file" ] && cp -p "$backup/$file" "/etc/config/$file"
	done

	reload_services
	log "restored backup: $backup"
}

delete_managed_network_section() {
	local section="$1"
	local managed

	config_get managed "$section" "$MANAGED_FLAG" "0"
	[ "$managed" = "1" ] && uci -q delete "network.$section"
}

delete_managed_wireless_section() {
	local section="$1"
	local managed

	config_get managed "$section" "$MANAGED_FLAG" "0"
	[ "$managed" = "1" ] && uci -q delete "wireless.$section"
}

delete_managed_dhcp_section() {
	local section="$1"
	local managed

	config_get managed "$section" "$MANAGED_FLAG" "0"
	[ "$managed" = "1" ] && uci -q delete "dhcp.$section"
}

delete_managed_firewall_section() {
	local section="$1"
	local managed

	config_get managed "$section" "$MANAGED_FLAG" "0"
	[ "$managed" = "1" ] && uci -q delete "firewall.$section"
}

cleanup_managed_configs() {
	config_load network
	config_foreach delete_managed_network_section device
	config_foreach delete_managed_network_section bridge-vlan
	config_foreach delete_managed_network_section interface

	config_load wireless
	config_foreach delete_managed_wireless_section wifi-iface

	config_load dhcp
	config_foreach delete_managed_dhcp_section dhcp

	if [ -f /etc/config/firewall ]; then
		config_load firewall
		config_foreach delete_managed_firewall_section zone
	fi
}

detach_port_from_bridge() {
	local section="$1"
	local type name port

	config_get type "$section" type
	config_get name "$section" name

	[ "$type" = "bridge" ] || return 0
	[ "$name" = "$BRIDGE" ] && return 0

	for port in $PORTS; do
		uci -q del_list "network.$section.ports=$port"
	done
}

detach_ports_from_existing_bridges() {
	config_load network
	config_foreach detach_port_from_bridge device
}

disable_existing_wifi_iface() {
	local section="$1"
	local managed

	config_get managed "$section" "$MANAGED_FLAG" "0"
	[ "$managed" = "1" ] && return 0
	uci set "wireless.$section.disabled=1"
}

disable_existing_wifi_ifaces() {
	[ "$DISABLE_EXISTING_WIFI" = "1" ] || return 0
	config_load wireless
	config_foreach disable_existing_wifi_iface wifi-iface
}

disable_dhcp_section() {
	local section="$1"

	uci set "dhcp.$section.ignore=1"
	uci set "dhcp.$section.ra=disabled"
	uci set "dhcp.$section.dhcpv6=disabled"
	uci set "dhcp.$section.ndp=disabled"
}

disable_existing_dhcp_servers() {
	[ "$DISABLE_ALL_DHCP" = "1" ] || return 0
	config_load dhcp
	config_foreach disable_dhcp_section dhcp
}

ensure_no_unmanaged_network_conflict() {
	local network="$1"
	local managed

	if uci -q get "network.$network" >/dev/null; then
		managed="$(uci -q get "network.$network.$MANAGED_FLAG" 2>/dev/null)"
		[ "$managed" = "1" ] || die "network.$network already exists and is not managed by vlanap"
	fi
}

create_bridge_device() {
	local port

	uci -q delete "network.vlanap_bridge"
	uci set "network.vlanap_bridge=device"
	uci set "network.vlanap_bridge.name=$BRIDGE"
	uci set "network.vlanap_bridge.type=bridge"
	uci set "network.vlanap_bridge.vlan_filtering=1"
	uci set "network.vlanap_bridge.$MANAGED_FLAG=1"

	for port in $PORTS; do
		uci add_list "network.vlanap_bridge.ports=$port"
	done
}

add_vlan_port_list() {
	local section="$1"
	local option="$2"
	local suffix="$3"
	local target="$4"

	ADD_VLAN_PORT_SECTION="$section"
	ADD_VLAN_PORT_SUFFIX="$suffix"
	ADD_VLAN_PORT_TARGET="$target"
	ADD_VLAN_PORT_COUNT=0
	config_list_foreach "$section" "$option" add_vlan_port
	[ "$ADD_VLAN_PORT_COUNT" -gt 0 ]
}

add_vlan_port() {
	local port="$1"
	local section="$ADD_VLAN_PORT_SECTION"
	local suffix="$ADD_VLAN_PORT_SUFFIX"
	local target="$ADD_VLAN_PORT_TARGET"

	valid_device_name "$port" || die "invalid port name in $section: $port"
	uci add_list "network.$target.ports=$port$suffix"
	ADD_VLAN_PORT_COUNT=$((ADD_VLAN_PORT_COUNT + 1))
}

create_vlan_network() {
	local section="$1"
	local id network bridge_vlan_section

	config_get id "$section" id
	config_get network "$section" network "$section"
	bridge_vlan_section="vlanap_bv_$network"

	ensure_no_unmanaged_network_conflict "$network"

	uci -q delete "network.$bridge_vlan_section"
	uci set "network.$bridge_vlan_section=bridge-vlan"
	uci set "network.$bridge_vlan_section.device=$BRIDGE"
	uci set "network.$bridge_vlan_section.vlan=$id"
	uci set "network.$bridge_vlan_section.$MANAGED_FLAG=1"

	if ! add_vlan_port_list "$section" tagged_port ":t" "$bridge_vlan_section"; then
		uci add_list "network.$bridge_vlan_section.ports=$UPLINK:t"
	fi

	add_vlan_port_list "$section" untagged_port ":u*" "$bridge_vlan_section" || true

	uci -q delete "network.$network"
	uci set "network.$network=interface"
	uci set "network.$network.device=$BRIDGE.$id"
	uci set "network.$network.$MANAGED_FLAG=1"

	if [ "$network" = "$MANAGE_NETWORK" ]; then
		uci set "network.$network.proto=static"
		uci set "network.$network.ipaddr=$MANAGE_IP"
		uci set "network.$network.netmask=$MANAGE_NETMASK"
		[ -n "$GATEWAY" ] && uci set "network.$network.gateway=$GATEWAY"
		[ -n "$DNS" ] && uci add_list "network.$network.dns=$DNS"
	else
		uci set "network.$network.proto=none"
	fi
}

create_managed_dhcp_section() {
	local network="$1"
	local dhcp_section="vlanap_dhcp_$network"

	uci -q delete "dhcp.$dhcp_section"
	uci set "dhcp.$dhcp_section=dhcp"
	uci set "dhcp.$dhcp_section.interface=$network"
	uci set "dhcp.$dhcp_section.$MANAGED_FLAG=1"
	disable_dhcp_section "$dhcp_section"
}

create_network_configs() {
	local section network

	detach_ports_from_existing_bridges
	config_load "$CONFIG"
	create_bridge_device

	for section in $VLAN_SECTIONS; do
		create_vlan_network "$section"
	done

	disable_existing_dhcp_servers

	for network in $NETWORKS; do
		create_managed_dhcp_section "$network"
	done
}

create_wifi_iface() {
	local section="$1"
	local radio="$2"
	local radio_index="${3:-0}"
	local iface network ssid encryption key isolate hidden macaddr iface_mac

	config_get network "$section" network
	config_get ssid "$section" ssid
	config_get encryption "$section" encryption "psk2+ccmp"
	config_get key "$section" key ""
	config_get isolate "$section" isolate ""
	config_get hidden "$section" hidden ""
	config_get macaddr "$section" macaddr ""

	iface="vlanap_${section}_${radio}"

	uci -q delete "wireless.$iface"
	uci set "wireless.$iface=wifi-iface"
	uci set "wireless.$iface.device=$radio"
	uci set "wireless.$iface.mode=ap"
	uci set "wireless.$iface.network=$network"
	uci set "wireless.$iface.ssid=$ssid"
	uci set "wireless.$iface.encryption=$encryption"
	uci set "wireless.$iface.$MANAGED_FLAG=1"

	[ "$encryption" != "none" ] && [ -n "$key" ] && uci set "wireless.$iface.key=$key"
	[ -n "$isolate" ] && uci set "wireless.$iface.isolate=$isolate"
	[ -n "$hidden" ] && uci set "wireless.$iface.hidden=$hidden"
	if [ -n "$macaddr" ]; then
		iface_mac="$(mac_add "$macaddr" "$radio_index")"
		uci set "wireless.$iface.macaddr=$iface_mac"
	fi
}

create_wireless_configs() {
	local section radio radio_index

	disable_existing_wifi_ifaces

	config_load wireless
	ALL_RADIOS=""
	config_foreach collect_radio_section wifi-device

	[ -n "$ALL_RADIOS" ] || {
		log "no wifi-device section found, skipping wireless config"
		return 0
	}

	config_load "$CONFIG"

	for section in $WIFI_SECTIONS; do
		WIFI_RADIOS=""
		radio_index=0
		config_list_foreach "$section" radio collect_wifi_radio
		[ -n "$WIFI_RADIOS" ] || WIFI_RADIOS="$ALL_RADIOS"

		for radio in $WIFI_RADIOS; do
			create_wifi_iface "$section" "$radio" "$radio_index"
			radio_index=$((radio_index + 1))
		done
	done
}
create_management_firewall_zone() {
	[ -f /etc/config/firewall ] || return 0
	[ -n "$MANAGE_FIREWALL_ZONE" ] || return 0

	uci -q delete "firewall.vlanap_mgmt"
	uci set "firewall.vlanap_mgmt=zone"
	uci set "firewall.vlanap_mgmt.name=$MANAGE_FIREWALL_ZONE"
	uci set "firewall.vlanap_mgmt.input=ACCEPT"
	uci set "firewall.vlanap_mgmt.output=ACCEPT"
	uci set "firewall.vlanap_mgmt.forward=REJECT"
	uci add_list "firewall.vlanap_mgmt.network=$MANAGE_NETWORK"
	uci set "firewall.vlanap_mgmt.$MANAGED_FLAG=1"
}

configure_dropbear_access() {
	local section

	[ -f /etc/config/dropbear ] || return 0

	for section in $(uci -q show dropbear | sed -n "s/^dropbear\.\([^.=]*\)=dropbear.*/\1/p"); do
		uci -q delete "dropbear.$section.Interface"
	done

	uci commit dropbear
}

apply_config() {
	cleanup_managed_configs
	config_load "$CONFIG"
	create_network_configs
	create_wireless_configs
	create_management_firewall_zone
	configure_dropbear_access
	uci commit network
	uci commit wireless
	uci commit dhcp
	[ -f /etc/config/firewall ] && uci commit firewall
	reload_services
}

start_safe_timer() {
	local backup="$1"
	local timeout="$2"
	local rollback_cmd

	echo "$backup" > "$SAFE_STATE"
	rollback_cmd="sleep $timeout; if [ -f $SAFE_STATE ]; then backup_dir=\$(cat $SAFE_STATE 2>/dev/null); rm -f $SAFE_STATE; [ -n \"\$backup_dir\" ] && /usr/sbin/vlanap restore \"\$backup_dir\" >/dev/null 2>&1; fi"

	if command -v nohup >/dev/null 2>&1; then
		nohup sh -c "$rollback_cmd" >/dev/null 2>&1 &
	else
		(sh -c "$rollback_cmd") >/dev/null 2>&1 &
	fi
}

cmd_apply() {
	local backup

	prepare_config
	backup="$(make_backup)"
	apply_config
	rm -f "$SAFE_STATE"
	log "applied config"
	log "backup: $backup"
}

cmd_apply_safe() {
	local backup

	prepare_config
	backup="$(make_backup)"
	start_safe_timer "$backup" "$SAFE_TIMEOUT"
	apply_config
	log "applied config with ${SAFE_TIMEOUT}s rollback timer"
	log "run 'vlanap confirm' after reconnecting"
	log "backup: $backup"
}

cmd_confirm() {
	if [ -f "$SAFE_STATE" ]; then
		rm -f "$SAFE_STATE"
		log "safe apply confirmed"
	else
		log "no pending safe apply"
	fi
}

delete_vlanap_sections() {
	local section

	config_load "$CONFIG"
	for section in $(uci -q show "$CONFIG" | sed -n "s/^$CONFIG\.\([^.=]*\)=.*/\1/p"); do
		uci -q delete "$CONFIG.$section"
	done
}

add_preset_vlan() {
	local section="$1"
	local id="$2"
	local network="$3"
	local access_port="$4"
	local sequence="$5"

	uci set "$CONFIG.$section=vlan"
	uci set "$CONFIG.$section.id=$id"
	uci set "$CONFIG.$section.network=$network"
	[ -n "$sequence" ] && uci set "$CONFIG.$section.sequence=$sequence"
	uci add_list "$CONFIG.$section.tagged_port=$UPLINK"
	[ -n "$access_port" ] && uci add_list "$CONFIG.$section.untagged_port=$access_port"
}

add_preset_wifi() {
	local section="$1"
	local network="$2"
	local ssid="$3"
	local key="$4"
	local macaddr="$5"
	local sequence="$6"

	uci set "$CONFIG.$section=wifi"
	uci set "$CONFIG.$section.network=$network"
	uci set "$CONFIG.$section.ssid=$ssid"
	uci set "$CONFIG.$section.encryption=psk2+ccmp"
	uci set "$CONFIG.$section.key=$key"
	[ -n "$macaddr" ] && uci set "$CONFIG.$section.macaddr=$macaddr"
	[ -n "$sequence" ] && uci set "$CONFIG.$section.sequence=$sequence"
}

random_byte_hex() {
	local byte

	byte="$(od -An -N1 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n')"
	case "$byte" in
		[0-9a-f][0-9a-f])
			echo "$byte"
			;;
		*)
			printf '%02x\n' $((( $(date +%s) + $$ ) & 255))
			;;
	esac
}

generate_random_mac() {
	local first b2 b3 b4 b5 b6

	first="$(random_byte_hex)"
	b2="$(random_byte_hex)"
	b3="$(random_byte_hex)"
	b4="$(random_byte_hex)"
	b5="$(random_byte_hex)"
	b6="$(random_byte_hex)"
	first=$(((0x$first & 252) | 2))

	printf '%02x:%s:%s:%s:%s:%s\n' "$first" "$b2" "$b3" "$b4" "$b5" "$b6"
}

generate_laa_group_base() {
	local first b2 b3 b4 b5

	first="$(random_byte_hex)"
	b2="$(random_byte_hex)"
	b3="$(random_byte_hex)"
	b4="$(random_byte_hex)"
	b5="$(random_byte_hex)"
	first=$(((0x$first & 252) | 2))

	printf '%02x:%s:%s:%s:%s:00\n' "$first" "$b2" "$b3" "$b4" "$b5"
}

select_vendor_oui() {
	local line

	if [ -f "$OUI_FILE" ]; then
		line="$(awk 'BEGIN { srand() } /^[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f][[:space:]]/ { if (rand() * ++n < 1) line=$0 } END { print line }' "$OUI_FILE")"
	fi

	[ -n "$line" ] || line="50:c7:bf TP-Link"
	echo "$line"
}

prepare_vendor_group_base() {
	local line oui b4 b5

	line="$(select_vendor_oui)"
	oui="$(echo "$line" | awk '{ print $1 }' | tr 'A-F' 'a-f')"
	MAC_VENDOR="$(echo "$line" | cut -d' ' -f2-)"
	b4="$(random_byte_hex)"
	b5="$(random_byte_hex)"
	MAC_BASE="$(printf '%s:%s:%s:00\n' "$oui" "$b4" "$b5")"
}

normalize_mac_mode() {
	case "$1" in
		""|auto)
			echo auto
			;;
		random|laa)
			echo random
			;;
		ap|vendor)
			echo "$1"
			;;
		*)
			return 1
			;;
	esac
}

mac_add() {
	local mac="$1"
	local offset="${2:-0}"
	local b1 b2 b3 b4 b5 b6 n carry

	valid_mac_or_empty "$mac" || die "invalid macaddr: $mac"
	case "$offset" in
		""|*[!0-9]*) die "invalid MAC offset: $offset" ;;
	esac

	b1="$(echo "$mac" | cut -d: -f1)"
	b2="$(echo "$mac" | cut -d: -f2)"
	b3="$(echo "$mac" | cut -d: -f3)"
	b4="$(echo "$mac" | cut -d: -f4)"
	b5="$(echo "$mac" | cut -d: -f5)"
	b6="$(echo "$mac" | cut -d: -f6)"

	n=$((0x$b6 + offset)); b6=$((n & 255)); carry=$((n >> 8))
	n=$((0x$b5 + carry)); b5=$((n & 255)); carry=$((n >> 8))
	n=$((0x$b4 + carry)); b4=$((n & 255)); carry=$((n >> 8))
	n=$((0x$b3 + carry)); b3=$((n & 255)); carry=$((n >> 8))
	n=$((0x$b2 + carry)); b2=$((n & 255)); carry=$((n >> 8))
	n=$((0x$b1 + carry)); b1=$((n & 255))

	printf '%02x:%02x:%02x:%02x:%02x:%02x\n' "$b1" "$b2" "$b3" "$b4" "$b5" "$b6"
}

mac_is_known() {
	local mac value

	mac="$(normalize_mac "$1")"
	for value in $GENERATED_MACS; do
		[ "$value" = "$mac" ] && return 0
	done

	return 1
}

remember_mac() {
	append_unique GENERATED_MACS "$(normalize_mac "$1")"
}

collect_existing_macs() {
	local section mac file

	GENERATED_MACS=""
	config_load "$CONFIG"
	for section in $(uci -q show "$CONFIG" | sed -n "s/^$CONFIG\.\([^.=]*\)=wifi.*/\1/p"); do
		config_get mac "$section" macaddr ""
		[ -n "$mac" ] && remember_mac "$mac"
	done

	for file in /sys/class/net/*/address; do
		[ -f "$file" ] || continue
		mac="$(cat "$file" 2>/dev/null)"
		case "$mac" in
			""|00:00:00:00:00:00|ff:ff:ff:ff:ff:ff)
				continue
				;;
		esac
		remember_mac "$mac"
	done
}

generate_unique_mac() {
	local tries mac

	tries=0
	while [ "$tries" -lt 100 ]; do
		mac="$(generate_random_mac)"
		if ! mac_is_known "$mac"; then
			remember_mac "$mac"
			echo "$mac"
			return 0
		fi
		tries=$((tries + 1))
	done

	die "failed to generate a unique Wi-Fi MAC"
}

prepare_mac_batch() {
	local mode="$1"
	local tries mac

	MAC_MODE="$mode"
	MAC_BASE=""
	MAC_VENDOR=""
	MAC_STRIDE=8

	case "$mode" in
		auto|random)
			return 0
			;;
		ap|vendor)
			tries=0
			while [ "$tries" -lt 100 ]; do
				if [ "$mode" = "vendor" ]; then
					prepare_vendor_group_base
				else
					MAC_BASE="$(generate_laa_group_base)"
				fi
				if ! mac_is_known "$MAC_BASE"; then
					return 0
				fi
				tries=$((tries + 1))
			done
			die "failed to generate a unique Wi-Fi MAC base"
			;;
	esac
}

generate_batch_mac() {
	local index="$1"
	local mac offset

	case "$MAC_MODE" in
		auto)
			return 0
			;;
		random)
			generate_unique_mac
			return 0
			;;
		ap|vendor)
			offset=$((index * MAC_STRIDE))
			mac="$(mac_add "$MAC_BASE" "$offset")"
			mac_is_known "$mac" && die "generated MAC collision: $mac"
			remember_mac "$mac"
			echo "$mac"
			return 0
			;;
	esac
}

store_mac_metadata() {
	local mode="$1"

	uci set "$CONFIG.main.mac_mode=$mode"
	if [ "$mode" = "ap" ] || [ "$mode" = "vendor" ]; then
		uci set "$CONFIG.main.mac_base=$MAC_BASE"
		[ -n "$MAC_VENDOR" ] && uci set "$CONFIG.main.mac_vendor=$MAC_VENDOR" || uci -q delete "$CONFIG.main.mac_vendor"
	else
		uci -q delete "$CONFIG.main.mac_base"
		uci -q delete "$CONFIG.main.mac_vendor"
	fi
}

delete_vlan_wifi_sections() {
	local section

	for section in $(uci -q show "$CONFIG" | sed -n "s/^$CONFIG\.\([^.=]*\)=\(vlan\|wifi\).*/\1/p"); do
		uci -q delete "$CONFIG.$section"
	done
}

word_at() {
	local want="$1"
	local index=1
	local value
	shift

	for value in "$@"; do
		if [ "$index" -eq "$want" ]; then
			echo "$value"
			return 0
		fi
		index=$((index + 1))
	done

	return 1
}

valid_ipv4_prefix2() {
	local a b

	case "$1" in
		*.*)
			a="${1%%.*}"
			b="${1#*.}"
			;;
		*)
			return 1
			;;
	esac

	case "$a:$b" in
		*[^0-9:]*|:*|*:|*::*)
			return 1
			;;
	esac

	[ "$a" -ge 1 ] 2>/dev/null && [ "$a" -le 223 ] 2>/dev/null && [ "$b" -ge 0 ] 2>/dev/null && [ "$b" -le 255 ] 2>/dev/null
}

valid_ipv4_host_octet() {
	case "$1" in
		""|*[!0-9]*)
			return 1
			;;
	esac
	[ "$1" -ge 1 ] 2>/dev/null && [ "$1" -le 254 ] 2>/dev/null
}

valid_positive_int() {
	case "$1" in
		""|*[!0-9]*)
			return 1
			;;
	esac
	[ "$1" -ge 1 ] 2>/dev/null
}

find_vlan_id_by_network() {
	local wanted="$1"
	local section network id

	for section in $(uci -q show "$CONFIG" | sed -n "s/^$CONFIG\.\([^.=]*\)=vlan.*/\1/p"); do
		network="$(uci -q get "$CONFIG.$section.network")"
		[ "$network" = "$wanted" ] || continue
		id="$(uci -q get "$CONFIG.$section.id")"
		[ -n "$id" ] && echo "$id"
		return 0
	done

	return 1
}

get_existing_max_sequence() {
	local manage_network="$1"
	local manage_vlan="$2"
	local max=0 section seq network fallback

	for section in $(uci -q show "$CONFIG" | sed -n "s/^$CONFIG\.\([^.=]*\)=wifi.*/\1/p"); do
		network="$(uci -q get "$CONFIG.$section.network")"
		[ "$network" = "$manage_network" ] && continue

		seq="$(uci -q get "$CONFIG.$section.sequence")"
		if ! valid_positive_int "$seq"; then
			fallback="$(find_vlan_id_by_network "$network" || true)"
			if valid_positive_int "$fallback" && [ "$fallback" != "$manage_vlan" ]; then
				seq="$fallback"
			else
				seq=""
			fi
		fi

		if valid_positive_int "$seq" && [ "$seq" -gt "$max" ] 2>/dev/null; then
			max="$seq"
		fi
	done

	echo "$max"
}

get_next_sequence() {
	local manage_network="${1:-$MANAGE_NETWORK}"
	local manage_vlan="${2:-$MANAGE_VLAN}"
	local stored max next

	stored="$(uci -q get "$CONFIG.main.next_sequence")"
	max="$(get_existing_max_sequence "$manage_network" "$manage_vlan")"
	next=$((max + 1))

	if valid_positive_int "$stored" && [ "$stored" -gt "$next" ] 2>/dev/null; then
		next="$stored"
	fi

	echo "$next"
}

store_next_sequence() {
	local candidate="$1"
	local current

	current="$(uci -q get "$CONFIG.main.next_sequence")"
	if ! valid_positive_int "$current" || [ "$candidate" -gt "$current" ] 2>/dev/null; then
		uci set "$CONFIG.main.next_sequence=$candidate"
	fi
}

cmd_batch_generate() {
	local start="${1:-auto}"
	local count="${2:-4}"
	local step="${3:-1}"
	local network_prefix="${4:-vlan}"
	local ssid_prefix="${5:-WiFi}"
	local key="$6"
	local uplink="${7:-lan1}"
	local access_csv="${8:-}"
	local mac_mode mode
	mac_mode="$(normalize_mac_mode "${9:-auto}")" || die "mac mode must be auto, random, ap, or vendor"
	mode="${10:-replace}"
	local manage_vlan="${11:-254}"
	local manage_access_port="${12:-lan2}"
	local ip_prefix="${13:-172.16}"
	local gateway_host="${14:-1}"
	local manage_host="${15:-254}"
	local access_ports port n id network section wifi_section ssid access_port mac
	local manage_network manage_section manage_wifi_section manage_ssid manage_ip gateway

	case "$count:$step" in
		*[^0-9:]*|:*|*:|*::*)
			die "count and step must be numbers"
			;;
	esac
	[ "$count" -ge 1 ] 2>/dev/null && [ "$count" -le 32 ] 2>/dev/null || die "count must be between 1 and 32"
	[ "$step" -ge 1 ] 2>/dev/null || die "step must be at least 1"
	valid_name "$network_prefix" || die "invalid network prefix: $network_prefix"
	[ -n "$ssid_prefix" ] || die "ssid prefix is required"
	validate_plain_wifi_key "$key"
	valid_device_name "$uplink" || die "invalid uplink port: $uplink"
	valid_vlan_id "$manage_vlan" || die "invalid management VLAN id: $manage_vlan"
	valid_device_name "$manage_access_port" || die "invalid management access port: $manage_access_port"
	[ "$manage_access_port" != "$uplink" ] || die "uplink port $uplink cannot be the management access port"
	valid_ipv4_prefix2 "$ip_prefix" || die "invalid IP prefix: $ip_prefix"
	valid_ipv4_host_octet "$gateway_host" || die "invalid RouterOS gateway host: $gateway_host"
	valid_ipv4_host_octet "$manage_host" || die "invalid AP management host: $manage_host"
	[ "$gateway_host" != "$manage_host" ] || die "RouterOS gateway host and AP management host cannot be the same"

	case "$mode" in
		replace|append) ;;
		*) die "mode must be replace or append" ;;
	esac

	access_ports="$(echo "$access_csv" | tr ',' ' ')"
	for port in $access_ports; do
		valid_device_name "$port" || die "invalid access port: $port"
		[ "$port" != "$uplink" ] || die "uplink port $uplink cannot be an access port"
		[ "$port" != "$manage_access_port" ] || die "management access port $manage_access_port cannot also be a business access port"
	done

	manage_network="${network_prefix}${manage_vlan}"
	manage_section="$manage_network"
	manage_wifi_section="${manage_network}_wifi"
	manage_ssid="${ssid_prefix}-${manage_vlan}"
	manage_ip="${ip_prefix}.${manage_vlan}.${manage_host}"
	gateway="${ip_prefix}.${manage_vlan}.${gateway_host}"

	valid_name "$manage_network" || die "generated management network name is invalid: $manage_network"

	[ "$(uci -q get "$CONFIG.main")" = "global" ] || uci set "$CONFIG.main=global"
	[ "$mode" = "replace" ] && delete_vlan_wifi_sections

	if [ "$start" = "auto" ]; then
		if [ "$mode" = "replace" ]; then
			start=1
			uci -q delete "$CONFIG.main.next_sequence"
		else
			start="$(get_next_sequence "$manage_network" "$manage_vlan")"
		fi
	fi

	case "$start" in
		""|*[!0-9]*)
			die "start must be a number or auto"
			;;
	esac
	[ "$start" -ge 1 ] 2>/dev/null || die "start must be at least 1"

	UPLINK="$uplink"
	collect_existing_macs
	prepare_mac_batch "$mac_mode"

	n=0
	while [ "$n" -lt "$count" ]; do
		id=$((start + n * step))
		valid_vlan_id "$id" || die "generated VLAN id is out of range: $id"
		[ "$id" != "$manage_vlan" ] || die "business VLAN $id collides with management VLAN $manage_vlan"
		network="${network_prefix}${id}"
		section="$network"
		wifi_section="${network}_wifi"
		ssid="${ssid_prefix}${id}"
		access_port="$(word_at $((n + 1)) $access_ports)"
		mac="$(generate_batch_mac "$n")"

		valid_name "$network" || die "generated network name is invalid: $network"
		[ "$section" != "main" ] || die "network name main is reserved"
		if [ "$mode" = "append" ] && uci -q get "$CONFIG.$section" >/dev/null; then
			die "section already exists: $section"
		fi
		if [ "$mode" = "append" ] && uci -q get "$CONFIG.$wifi_section" >/dev/null; then
			die "section already exists: $wifi_section"
		fi

		add_preset_vlan "$section" "$id" "$network" "$access_port" "$id"
		add_preset_wifi "$wifi_section" "$network" "$ssid" "$key" "$mac" "$id"

		n=$((n + 1))
	done

	if ! uci -q get "$CONFIG.$manage_section" >/dev/null; then
		add_preset_vlan "$manage_section" "$manage_vlan" "$manage_network" "$manage_access_port"
	fi
	if ! uci -q get "$CONFIG.$manage_wifi_section" >/dev/null; then
		mac="$(generate_batch_mac "$count")"
		add_preset_wifi "$manage_wifi_section" "$manage_network" "$manage_ssid" "$key" "$mac"
	fi

	uci set "$CONFIG.main.enabled=1"
	uci set "$CONFIG.main.uplink=$uplink"
	uci set "$CONFIG.main.manage_network=$manage_network"
	uci set "$CONFIG.main.manage_vlan=$manage_vlan"
	uci set "$CONFIG.main.bridge=br-vlanap"
	uci set "$CONFIG.main.manage_ip=$manage_ip"
	uci set "$CONFIG.main.manage_netmask=255.255.255.0"
	uci set "$CONFIG.main.gateway=$gateway"
	uci set "$CONFIG.main.dns=$gateway"
	uci set "$CONFIG.main.safe_timeout=180"
	uci set "$CONFIG.main.disable_existing_wifi=1"
	uci set "$CONFIG.main.disable_all_dhcp=1"
	uci set "$CONFIG.main.manage_firewall_zone=vlanap_mgmt"
	store_mac_metadata "$mac_mode"
	store_next_sequence $((start + count * step))

	uci commit "$CONFIG"
	log "generated $count Wi-Fi entries from internal number $start"
	log "management: $manage_ssid vlan=$manage_vlan ip=$manage_ip gateway=$gateway"
}

cmd_mac_generate() {
	local target="${1:-all}"
	local mode section mac count index

	mode="$(normalize_mac_mode "${2:-random}")" || die "mac mode must be auto, random, ap, or vendor"

	collect_existing_macs
	prepare_mac_batch "$mode"

	if [ "$target" = "all" ]; then
		count=0
		index=0
		for section in $(uci -q show "$CONFIG" | sed -n "s/^$CONFIG\.\([^.=]*\)=wifi.*/\1/p"); do
			if [ "$mode" = "auto" ]; then
				uci -q delete "$CONFIG.$section.macaddr"
				echo "$section auto"
			else
				mac="$(generate_batch_mac "$index")"
				uci set "$CONFIG.$section.macaddr=$mac"
				echo "$section $mac"
			fi
			count=$((count + 1))
			index=$((index + 1))
		done
		[ "$count" -gt 0 ] || die "no wifi section found"
		store_mac_metadata "$mode"
		uci commit "$CONFIG"
		return 0
	fi

	[ "$(uci -q get "$CONFIG.$target")" = "wifi" ] || die "wifi section not found: $target"
	if [ "$mode" = "auto" ]; then
		uci -q delete "$CONFIG.$target.macaddr"
		echo "$target auto"
	else
		mac="$(generate_batch_mac 0)"
		uci set "$CONFIG.$target.macaddr=$mac"
		echo "$target $mac"
	fi
	uci commit "$CONFIG"
}

cmd_mac_clear() {
	local target="${1:-all}"
	local section count

	if [ "$target" = "all" ]; then
		count=0
		for section in $(uci -q show "$CONFIG" | sed -n "s/^$CONFIG\.\([^.=]*\)=wifi.*/\1/p"); do
			uci -q delete "$CONFIG.$section.macaddr"
			echo "$section auto"
			count=$((count + 1))
		done
		[ "$count" -gt 0 ] || die "no wifi section found"
		uci -q delete "$CONFIG.main.mac_base"
		uci -q delete "$CONFIG.main.mac_vendor"
		uci set "$CONFIG.main.mac_mode=auto"
		uci commit "$CONFIG"
		return 0
	fi

	[ "$(uci -q get "$CONFIG.$target")" = "wifi" ] || die "wifi section not found: $target"
	uci -q delete "$CONFIG.$target.macaddr"
	uci commit "$CONFIG"
	echo "$target auto"
}

show_runtime_wifi_macs() {
	local wanted_ssid="$1"
	local line iface ssid mac

	command -v iw >/dev/null 2>&1 || return 0

	iw dev 2>/dev/null | while IFS= read -r line; do
		line="$(echo "$line" | sed 's/^[[:space:]]*//')"
		case "$line" in
			Interface\ *)
				iface="${line#Interface }"
				;;
			ssid\ *)
				ssid="${line#ssid }"
				if [ "$ssid" = "$wanted_ssid" ] && [ -n "$iface" ] && [ -f "/sys/class/net/$iface/address" ]; then
					mac="$(cat "/sys/class/net/$iface/address" 2>/dev/null)"
					[ -n "$mac" ] && echo "  runtime.$iface ssid=$ssid mac=$mac"
				fi
				;;
		esac
	done
}

cmd_wifi_status() {
	local section network ssid mac generated gmac radio

	config_load "$CONFIG"
	for section in $(uci -q show "$CONFIG" | sed -n "s/^$CONFIG\.\([^.=]*\)=wifi.*/\1/p"); do
		config_get network "$section" network "-"
		config_get ssid "$section" ssid "-"
		config_get mac "$section" macaddr "auto"
		echo "wifi.$section network=$network ssid=$ssid base_mac=$mac"

		for generated in $(uci -q show wireless | sed -n "s/^wireless\.\(vlanap_${section}_[^.]*\)=wifi-iface.*/\1/p"); do
			gmac="$(uci -q get "wireless.$generated.macaddr")"
			radio="$(uci -q get "wireless.$generated.device")"
			[ -n "$gmac" ] || gmac="auto"
			echo "  wireless.$generated radio=$radio configured_wireless_mac=$gmac"
		done
		show_runtime_wifi_macs "$ssid"
	done
}
write_routeros_basic_preset() {
	local key="$1"
	local n id network wifi_section ssid

	[ -n "$key" ] || key="change-this-password"

	delete_vlanap_sections

	UPLINK="lan1"
	uci set "$CONFIG.main=global"
	uci set "$CONFIG.main.enabled=1"
	uci set "$CONFIG.main.bridge=br-vlanap"
	uci set "$CONFIG.main.uplink=$UPLINK"
	uci set "$CONFIG.main.manage_network=vlan254"
	uci set "$CONFIG.main.manage_vlan=254"
	uci set "$CONFIG.main.manage_ip=172.16.254.254"
	uci set "$CONFIG.main.manage_netmask=255.255.255.0"
	uci set "$CONFIG.main.gateway=172.16.254.1"
	uci set "$CONFIG.main.dns=172.16.254.1"
	uci set "$CONFIG.main.safe_timeout=180"
	uci set "$CONFIG.main.disable_existing_wifi=1"
	uci set "$CONFIG.main.disable_all_dhcp=1"
	uci set "$CONFIG.main.manage_firewall_zone=vlanap_mgmt"
	uci set "$CONFIG.main.mac_mode=auto"
	uci set "$CONFIG.main.next_sequence=5"
	uci -q delete "$CONFIG.main.mac_base"
	uci -q delete "$CONFIG.main.mac_vendor"

	n=1
	while [ "$n" -le 4 ]; do
		id="$n"
		network="vlan${id}"
		wifi_section="${network}_wifi"
		ssid="WiFi${id}"
		add_preset_vlan "$network" "$id" "$network" "" "$id"
		add_preset_wifi "$wifi_section" "$network" "$ssid" "$key" "" "$id"
		n=$((n + 1))
	done

	add_preset_vlan vlan254 254 vlan254 lan2
	add_preset_wifi vlan254_wifi vlan254 WiFi-254 "$key"

	uci commit "$CONFIG"
	log "routeros-basic preset saved: WiFi1..WiFi4 plus WiFi-254 management"
}
cmd_preset() {
	local mode="${1:-routeros-basic}"
	local key="$2"

	case "$mode" in
		routeros-basic|basic)
			write_routeros_basic_preset "$key"
			;;
		*)
			die "unknown preset: $mode"
			;;
	esac
}

cmd_quick_apply() {
	local key="$1"

	validate_plain_wifi_key "$key"
	write_routeros_basic_preset "$key"
	cmd_apply_safe
}

cmd_restore() {
	local backup="$1"

	[ -n "$backup" ] || backup="$BACKUP_ROOT/latest"
	restore_from "$backup"
	rm -f "$SAFE_STATE"
}

show_vlan_status() {
	local section id network sequence

	for section in $VLAN_SECTIONS; do
		config_get id "$section" id
		config_get network "$section" network "$section"
		config_get sequence "$section" sequence ""
		if [ -n "$sequence" ]; then
			echo "  #$sequence VLAN $id -> $network"
		else
			echo "  VLAN $id -> $network"
		fi
	done
}

show_generated_interfaces() {
	local section proto device

	for section in $(uci -q show network | sed -n "s/^network\.\([^.=]*\)\.$MANAGED_FLAG='1'.*/\1/p"); do
		config_get proto "$section" proto "-"
		config_get device "$section" device "-"
		echo "  network.$section proto=$proto device=$device"
	done
}

cmd_status() {
	load_vlanap_config
	echo "enabled: $ENABLED"
	echo "bridge: $BRIDGE"
	echo "uplink: $UPLINK"
	echo "management: $MANAGE_NETWORK vlan=$MANAGE_VLAN ip=$MANAGE_IP"
	echo "next Wi-Fi number: $(get_next_sequence "$MANAGE_NETWORK" "$MANAGE_VLAN")"
	echo "safe timeout: $SAFE_TIMEOUT"
	echo "configured VLANs:"
	show_vlan_status
	echo "configured Wi-Fi:"
	cmd_wifi_status
	echo "generated network sections:"
	config_load network
	show_generated_interfaces
	if [ -f "$SAFE_STATE" ]; then
		echo "safe rollback: pending ($(cat "$SAFE_STATE" 2>/dev/null))"
	else
		echo "safe rollback: none"
	fi
}

case "$1" in
	apply)
		cmd_apply
		;;
	apply-safe)
		cmd_apply_safe
		;;
	confirm)
		cmd_confirm
		;;
	preset)
		shift
		cmd_preset "$@"
		;;
	quick-apply)
		shift
		cmd_quick_apply "$@"
		;;
	batch-generate)
		shift
		cmd_batch_generate "$@"
		;;
	mac-generate)
		shift
		cmd_mac_generate "$@"
		;;
	mac-clear)
		shift
		cmd_mac_clear "$1"
		;;
	wifi-status)
		cmd_wifi_status
		;;
	backup)
		make_backup
		;;
	restore)
		shift
		cmd_restore "$1"
		;;
	status)
		cmd_status
		;;
	-h|--help|help|"")
		usage
		;;
	*)
		usage >&2
		exit 1
		;;
esac
